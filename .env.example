# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.

# ─── Production URL (recommended in Vercel Production) ───
# Used for sitemap.xml, robots.txt, and Open Graph absolute URLs.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── Google Search Console (HTML tag verification) ───
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Bing Webmaster Tools
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Optional: Yandex Webmaster
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ─── Google AdSense ───
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_ADS_TXT_LINE=
